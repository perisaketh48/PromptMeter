# ----- Django core -----
SECRET_KEY=replace-with-strong-random-value
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend
TIME_ZONE=UTC
LOG_LEVEL=INFO

# ----- CORS -----
# Comma-separated list of origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ----- Database -----
# When using docker-compose, host = "db". For local native dev use "localhost".
DATABASE_URL=postgres://aitoken:aitoken@db:5432/aitoken

# Used by the postgres service in docker-compose.yml
POSTGRES_DB=aitoken
POSTGRES_USER=aitoken
POSTGRES_PASSWORD=aitoken
POSTGRES_PORT=5432

# ----- JWT -----
# Leave JWT_SIGNING_KEY blank to fall back to SECRET_KEY (not recommended in prod)
JWT_SIGNING_KEY=
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# ----- Encryption (vendor API key vault, used in later steps) -----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ----- Email -----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com
